{
  "name": "temp-expense-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "version:bump": "node -e \"const fs=require('fs'), p='src/lib/version.ts', c=fs.readFileSync(p,'utf8'), v=c.match(/'([^']+)'/)[1], pv=v.split('.').map(Number);pv[2]++;fs.writeFileSync(p,c.replace(v,pv.join('.')));console.log('v'+pv.join('.'))\" && git add src/lib/version.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "idb": "^8.0.3",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "fake-indexeddb": "^6.2.5",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "typescript": "^5"
  }
}
